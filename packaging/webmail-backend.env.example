# Installers should render this file to:
# /etc/openmailstack/webmail-backend.env
#
# Do not commit a populated copy. It contains the database password.

OMS_WEBMAIL_HOST=127.0.0.1
OMS_WEBMAIL_PORT=20000
OMS_PUBLIC_BASE_URL=https://mail.example.com
OMS_DEFAULT_DOMAIN=example.com

OMS_DB_HOST=127.0.0.1
OMS_DB_PORT=3306
OMS_DB_NAME=postfixadmin
OMS_DB_USER=postfixadmin
OMS_DB_PASSWORD=replace-with-generated-postfixadmin-password

OMS_IMAP_HOST=127.0.0.1
OMS_IMAP_PORT=143
OMS_IMAP_SECURE=false
OMS_IMAP_REJECT_UNAUTHORIZED=true

OMS_SMTP_HOST=127.0.0.1
OMS_SMTP_PORT=25
OMS_SMTP_SECURE=false
OMS_SMTP_REJECT_UNAUTHORIZED=true

OMS_SIEVE_HOST=127.0.0.1
OMS_SIEVE_PORT=4190

OMS_SESSION_TTL_SECONDS=28800
OMS_COOKIE_SECURE=true
OMS_UPLOAD_LIMIT_BYTES=26214400
